{
  "name": "@paavonykanen/airo",
  "version": "0.1.0",
  "description": "Generate AI coding assistant steering files based on installed npm packages",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "airo": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@clack/prompts": "^0.10.1",
    "@google/genai": "^1.0.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "openai": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}